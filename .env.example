# iMobile .env — Environment Variables Template
# Copy this file to .env and fill in your values.
# cp .env.example .env

# ── Required API Keys ───────────────────────────────────────────
# Tushare (stock data, required ~2000+ points)
TUSHARE_TOKEN=your_tushare_token_here

# Gemini AI (free tier: https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# ── Mobile App ───────────────────────────────────────────────────
GUOTAI_PACKAGE_NAME=com.guotai.dazhihui
GUOTAI_PASSWORD=your_6_digit_trading_pin

# ── Optional AI Providers ────────────────────────────────────────
# OPENROUTER_API_KEY=your_openrouter_key
# DEEPSEEK_API_KEY=your_deepseek_key
# XAI_API_KEY=your_xai_key

# ── Optional Search Providers ────────────────────────────────────
# SEARCHAPI_API_KEY=your_searchapi_key
# TAVILY_API_KEY=your_tavily_key
# OXYLABS_USERNAME=your_oxylabs_user
# OXYLABS_PASSWORD=your_oxylabs_pass

# ── Paths ────────────────────────────────────────────────────────
BACKTEST_PATH=./backtest
CONFIG_FILE=${BACKTEST_PATH}/config.json
REPORT_PATH=${BACKTEST_PATH}/results
LOG_PATH=./logs
CACHE_PATH=./shared/data_cache
DB_CACHE_FILE=./shared/db/db_cache.db
DB_IMOBILE_FILE=./shared/db/imobile.db
DBTEST_IMOBILE_FILE=./shared/db/test_imobile.db

# ── General Settings ─────────────────────────────────────────────
LOG_LEVEL=INFO
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_THINKING_BUDGET=-1

# ── Backtest Strategy Parameters ─────────────────────────────────
# See docs/ENV_VARS.md for full documentation.

# Stop-Loss per regime
SL_BULL=0.025
SL_NORMAL=0.025
SL_VOLATILE=0.02
SL_BEAR=0.015

# Stop-Loss behavior
SL_ENABLED=true
SL_WITH_RE_PICK=false
SL_WIDEN_STEP=0.005
SL_WIDEN_AFTER=2

# Position sizing & scoring
SCORE_MIN=0
POS_SCORE_WEIGHT=false
HOLD_DAYS_MULT=0.5

# Buy/sell filters
SKIP_GAPS_DOWN_OPEN_PRICE=false
INDEX_TREND_FILTER=false
ER_EXIT_ENABLED=true
BALANCE_PRICE_RATIO=0.0
POSITION_SIZING_ALGORITHM=true
BACKTEST_BUY_OPEN_PRICE=true

# Real trading
START_REAL_TRADING_DATE=2026-06-29
