# iMobile .gitignore
# -------------------
# Architecture: mono-repo with web app (Reflex), backtest engine,
# mobile automation (DroidRun), and stock strategy modules.

# ── Secrets & Environment ──────────────────────────────────
.env
.envrc
.env.*
!.env.example

# ── Python ─────────────────────────────────────────────────
.venv/
venv/
env/
*.py[codz]
*$py.class
__pycache__/
*.egg-info/
.eggs/
dist/
build/
develop-eggs/

# ── Database & Cache ───────────────────────────────────────
*.db
*.db-journal
*.db-wal
*.db-shm
data_cache/
data/
backups/
db/go_daily_cache/

# ── Backtest Outputs & Logs ────────────────────────────────
*.log
/backtest/backtest_results/
/logs/

# ── IDE & Editor ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.cursorindexingignore

# ── Web Frontend (Reflex) ──────────────────────────────────
.web/
.states/
assets/external/

# ── Mobile Automation ──────────────────────────────────────
trajectories/

# ── Testing ────────────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
.coverage.*
tests/_*

# ── Misc Tools ─────────────────────────────────────────────
GIT.sh
.mypy_cache/
.ruff_cache/
.webassets-cache

# ── Workspace artifacts ─────────────────────────────────────
docs/oxylabs/
docs/skills/
docs/wechat-articles/
tests/.last_sogou.html
tests/.proxy_repos/
tests/test_free_residential_proxies.md
tests/test_free_residential_proxies.py
utils/wechat_article_by_title_proxy.py
